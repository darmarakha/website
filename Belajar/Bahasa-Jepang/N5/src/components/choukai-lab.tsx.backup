'use client';

import React, { useState, useRef, useEffect, useCallback } from 'react';
import {
  Volume2, VolumeX, Play, Pause, ChevronRight, Sparkles,
  CheckCircle2, XCircle, Headphones,
  BookOpen, Loader2, Gauge, User, Users,
  Eye, EyeOff, MessageCircle, ArrowRight, Globe,
} from 'lucide-react';
import { Card } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Badge } from '@/components/ui/badge';
import { Slider } from '@/components/ui/slider';
import { cn } from '@/lib/utils';
import {
  N5_CHOUKAI_MATERIALS,
  type ChoukaiMaterial,
  type ChoukaiSpeaker,
} from '@/lib/n5-data';

// Parse furigana: Kanji[hiragana] -> ruby annotations
function parseFurigana(text: string) {
  const regex = /([一-龯々]+)\[([ぁ-んァ-ン]+)\]/g;
  const parts: React.ReactNode[] = [];
  let lastIndex = 0;
  let match;
  let keyIdx = 0;
  while ((match = regex.exec(text)) !== null) {
    if (match.index > lastIndex) {
      parts.push(text.substring(lastIndex, match.index));
    }
    parts.push(
      <ruby key={`furi-${keyIdx++}`} className="[ruby-position:under] mx-0.5">
        {match[1]}
        <rt className="text-[10px] text-sky-600 tracking-tighter leading-none mb-1 opacity-90 font-bold">
          {match[2]}
        </rt>
      </ruby>
    );
    lastIndex = regex.lastIndex;
  }
  if (lastIndex < text.length) {
    parts.push(text.substring(lastIndex));
  }
  return parts.length > 0 ? parts : text;
}

// Clean text for speech — IMPORTANT: convert Kanji[furigana] to just furigana reading
// This ensures the TTS engine reads Japanese pronunciation instead of Chinese kanji pronunciation
function cleanForSpeech(text: string): string {
  const emojiRegex = /[\u{1F600}-\u{1F64F}\u{1F300}-\u{1F5FF}\u{1F680}-\u{1F6FF}\u{1F1E0}-\u{1F1FF}\u{2600}-\u{26FF}\u{2700}-\u{27BF}\u{FE00}-\u{FE0F}\u{1F900}-\u{1F9FF}\u{1FA00}-\u{1FA6F}\u{1FA70}-\u{1FAFF}\u{200D}\u{20E3}\u{E0020}-\u{E007F}]/gu;
  let cleaned = text.replace(emojiRegex, '');
  // Convert Kanji[hiragana] → hiragana only (e.g., 私[わたし] → わたし)
  // This is critical because Chinese TTS voices would read kanji with Chinese pronunciation
  cleaned = cleaned.replace(/([一-龯々]+)\[([ぁ-んァ-ンー]+)\]/g, '$2');
  // Remove any remaining brackets that don't match the furigana pattern
  cleaned = cleaned.replace(/\[.*?\]/g, '');
  // Remove markdown formatting
  cleaned = cleaned.replace(/[*#]/g, '');
  return cleaned.trim();
}

// --- Voice Selection: Try to find DIFFERENT voices for male and female speakers ---
function getJapaneseVoices(): { female: SpeechSynthesisVoice | null; male: SpeechSynthesisVoice | null; default: SpeechSynthesisVoice | null } {
  if (typeof window === 'undefined' || !('speechSynthesis' in window)) return { female: null, male: null, default: null };

  const voices = window.speechSynthesis.getVoices();
  const jaVoices = voices.filter(v => v.lang === 'ja-JP' || v.lang.startsWith('ja'));

  // Try to find distinct female and male voices
  const femaleVoice = jaVoices.find(v => /female|woman|女/i.test(v.name))
    || jaVoices.find(v => /Google.*日本/i.test(v.name) && !/male/i.test(v.name))
    || jaVoices.find(v => /Microsoft.*Haruka/i.test(v.name))
    || jaVoices.find(v => /Microsoft.*Ayumi/i.test(v.name))
    || jaVoices.find(v => /Microsoft.*Nanami/i.test(v.name))
    || jaVoices.find(v => /Google/i.test(v.name));

  const maleVoice = jaVoices.find(v => /male|man|男/i.test(v.name))
    || jaVoices.find(v => /Microsoft.*Ichiro/i.test(v.name))
    || jaVoices.find(v => /Microsoft.*Show/i.test(v.name))
    || jaVoices.find(v => /Microsoft.*Takumi/i.test(v.name))
    || jaVoices.find(v => /Google.*日本.*男/i.test(v.name))
    || jaVoices.find(v => /Kyoko/i.test(v.name) ? false : /Google/i.test(v.name) && !femaleVoice?.name.includes(v.name));

  const defaultVoice = jaVoices[0] || null;

  // If we couldn't find distinct voices, at least return something
  return {
    female: femaleVoice || defaultVoice,
    male: maleVoice || defaultVoice,
    default: defaultVoice,
  };
}

// Get speaker info from material
function getSpeakerInfo(material: ChoukaiMaterial, speakerId: string): ChoukaiSpeaker | undefined {
  return material.speakers.find(s => s.id === speakerId);
}

// Get color classes for a speaker
function getSpeakerColors(speakerId: string, material: ChoukaiMaterial) {
  const speaker = getSpeakerInfo(material, speakerId);
  if (!speaker) return { bg: 'bg-gray-100', border: 'border-gray-300', text: 'text-gray-700', activeBg: 'bg-gray-100', ring: 'ring-gray-400' };

  if (speaker.colorClass === 'rose') {
    return {
      bg: 'bg-rose-50 dark:bg-rose-950/30',
      border: 'border-rose-200',
      text: 'text-rose-700 dark:text-rose-400',
      badge: 'bg-rose-500',
      activeBg: 'bg-rose-100 dark:bg-rose-900/30',
      ring: 'ring-rose-400',
      gradient: 'from-rose-400 to-pink-500',
      shadow: 'shadow-rose-200',
    };
  }
  return {
    bg: 'bg-blue-50 dark:bg-blue-950/30',
    border: 'border-blue-200',
    text: 'text-blue-700 dark:text-blue-400',
    badge: 'bg-blue-500',
    activeBg: 'bg-blue-100 dark:bg-blue-900/30',
    ring: 'ring-blue-400',
    gradient: 'from-blue-400 to-indigo-500',
    shadow: 'shadow-blue-200',
  };
}

export default function ChoukaiLab() {
  const [materials, setMaterials] = useState<ChoukaiMaterial[]>(N5_CHOUKAI_MATERIALS);
  const [currentMaterial, setCurrentMaterial] = useState<ChoukaiMaterial | null>(null);
  const [currentIndex, setCurrentIndex] = useState(0);
  const [isPlaying, setIsPlaying] = useState(false);
  const [activeSpeakingIdx, setActiveSpeakingIdx] = useState<number | null>(null);
  const [showScript, setShowScript] = useState(false);
  const [selectedAnswer, setSelectedAnswer] = useState<number | null>(null);
  const [score, setScore] = useState({ correct: 0, total: 0 });
  const [aiMaterial, setAiMaterial] = useState<ChoukaiMaterial | null>(null);
  const [isGenerating, setIsGenerating] = useState(false);
  const [activeTab, setActiveTab] = useState<'library' | 'ai'>('library');

  // Fetch materials from API
  useEffect(() => {
    const fetchMaterials = async () => {
      try {
        const res = await fetch('/api/materials');
        if (res.ok) {
          const data = await res.json();
          if (data && data.length > 0) {
            setMaterials(data);
          }
        }
      } catch (err) {
        console.error('Failed to fetch materials:', err);
      }
    };
    fetchMaterials();
  }, []);

  const [playbackSpeed, setPlaybackSpeed] = useState(0.85);
  const [hasStartedQuiz, setHasStartedQuiz] = useState(false);
  const [activeSpeakerId, setActiveSpeakerId] = useState<string | null>(null);
  const [voicesReady, setVoicesReady] = useState(false);
  const [audioMode, setAudioMode] = useState<'ai' | 'browser'>('ai');
  const [isPreGenerating, setIsPreGenerating] = useState(false);
  const [preGenProgress, setPreGenProgress] = useState({ current: 0, total: 0 });
  const [ttsReady, setTtsReady] = useState(false);
  const [playedLines, setPlayedLines] = useState(0);

  const scrollRef = useRef<HTMLDivElement>(null);
  const playTimeoutRef = useRef<NodeJS.Timeout[]>([]);
  const stopFlagRef = useRef(false);
  const voicesRef = useRef<{ female: SpeechSynthesisVoice | null; male: SpeechSynthesisVoice | null; default: SpeechSynthesisVoice | null }>({ female: null, male: null, default: null });
  const ttsCacheRef = useRef<Map<string, string>>(new Map());
  const currentAudioRef = useRef<HTMLAudioElement | null>(null);
  const preGenAbortRef = useRef(false);
  const chromeResumeRef = useRef<ReturnType<typeof setInterval> | null>(null);

  // Initialize voices
  useEffect(() => {
    const loadVoices = () => {
      voicesRef.current = getJapaneseVoices();
      setVoicesReady(true);
    };

    if (typeof window !== 'undefined' && 'speechSynthesis' in window) {
      loadVoices();
      window.speechSynthesis.addEventListener('voiceschanged', loadVoices);
    }

    return () => {
      if (typeof window !== 'undefined' && 'speechSynthesis' in window) {
        window.speechSynthesis.removeEventListener('voiceschanged', loadVoices);
        window.speechSynthesis.cancel();
      }
      playTimeoutRef.current.forEach(t => clearTimeout(t));
      if (chromeResumeRef.current) {
        clearInterval(chromeResumeRef.current);
        chromeResumeRef.current = null;
      }
    };
  }, []);

  useEffect(() => {
    if (materials.length > 0) {
      setCurrentMaterial(materials[0]);
    }
  }, [materials]);

  useEffect(() => {
    if (showScript && scrollRef.current && activeSpeakingIdx !== null) {
      const el = scrollRef.current.querySelector(`[data-line="${activeSpeakingIdx}"]`);
      if (el) el.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }, [showScript, activeSpeakingIdx]);

  // --- Pre-generate TTS audio for all dialogue lines ---
  const preGenerateDialogueAudio = useCallback(async (material: ChoukaiMaterial) => {
    if (audioMode !== 'ai') return;

    preGenAbortRef.current = false;
    setIsPreGenerating(true);
    setPreGenProgress({ current: 0, total: material.dialogue.length });
    setTtsReady(false);

    const cache = ttsCacheRef.current;

    for (let i = 0; i < material.dialogue.length; i++) {
      if (preGenAbortRef.current) break;

      const key = `${material.id}-${i}`;
      if (cache.has(key)) {
        setPreGenProgress(prev => ({ ...prev, current: i + 1 }));
        continue;
      }

      const line = material.dialogue[i];
      const cleanText = cleanForSpeech(line.text);
      if (!cleanText) {
        setPreGenProgress(prev => ({ ...prev, current: i + 1 }));
        continue;
      }

      const speaker = getSpeakerInfo(material, line.speaker);
      const speakerType = speaker?.gender === 'wanita' ? 'A' : 'B';

      try {
        const res = await fetch('/api/tts', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text: cleanText, speaker: speakerType }),
        });

        if (res.ok) {
          const blob = await res.blob();
          const url = URL.createObjectURL(blob);
          cache.set(key, url);
        }
        // Server-side handles retries now, so no need for client retry
      } catch (err) {
        console.warn(`Gagal pre-gen audio baris ${i}:`, err);
      }

      setPreGenProgress(prev => ({ ...prev, current: i + 1 }));

      // Add delay between requests to avoid rate limiting (1s)
      if (i < material.dialogue.length - 1 && !preGenAbortRef.current) {
        await new Promise<void>(resolve => {
          const t = setTimeout(resolve, 1000);
          playTimeoutRef.current.push(t);
        });
      }
    }

    setIsPreGenerating(false);
    const generatedCount = material.dialogue.filter((_, i) => cache.has(`${material.id}-${i}`)).length;
    setTtsReady(generatedCount === material.dialogue.length);
  }, [audioMode]);

  // --- Speaker voice parameters ---
  // DRAMATIC differentiation between speakers
  const getSpeakerVoiceParams = useCallback((speakerId: string, material: ChoukaiMaterial, baseSpeed: number) => {
    const speaker = getSpeakerInfo(material, speakerId);
    const isFemale = speaker?.gender === 'wanita';

    // Female: higher pitch, slightly faster, clearer
    // Male: much lower pitch, slightly slower, deeper
    const voices = voicesRef.current;
    let voice: SpeechSynthesisVoice | null = null;

    if (voices.female && voices.male && voices.female !== voices.male) {
      voice = isFemale ? voices.female : voices.male;
    } else {
      voice = voices.default;
    }

    return {
      voice,
      pitch: isFemale ? 1.5 : 0.5,
      rate: isFemale ? Math.min(baseSpeed * 1.05, 1.2) : Math.max(baseSpeed * 0.85, 0.5),
      volume: 1.0,
    };
  }, []);

  // --- Chrome 15-second workaround: periodic resume to prevent pause ---
  const startChromeResume = useCallback(() => {
    if (typeof window === 'undefined' || !('speechSynthesis' in window)) return;
    stopChromeResume();
    chromeResumeRef.current = setInterval(() => {
      if (window.speechSynthesis.speaking && !window.speechSynthesis.paused) {
        window.speechSynthesis.pause();
        window.speechSynthesis.resume();
      }
    }, 10000);
  }, []);

  const stopChromeResume = useCallback(() => {
    if (chromeResumeRef.current) {
      clearInterval(chromeResumeRef.current);
      chromeResumeRef.current = null;
    }
  }, []);

  // --- Play single audio blob via HTML5 Audio ---
  const playAudioBlob = useCallback((blobUrl: string): Promise<void> => {
    return new Promise<void>((resolve) => {
      if (stopFlagRef.current) { resolve(); return; }
      const audio = new Audio(blobUrl);
      currentAudioRef.current = audio;
      audio.playbackRate = playbackSpeed;

      const onEnd = () => {
        cleanup();
        resolve();
      };
      const onError = () => {
        cleanup();
        resolve(); // don't reject, just skip
      };
      const cleanup = () => {
        audio.removeEventListener('ended', onEnd);
        audio.removeEventListener('error', onError);
        if (currentAudioRef.current === audio) {
          currentAudioRef.current = null;
        }
      };

      audio.addEventListener('ended', onEnd);
      audio.addEventListener('error', onError);
      audio.play().catch(() => { cleanup(); resolve(); });
    });
  }, [playbackSpeed]);

  // --- AI Audio dialog playback (pre-generated TTS) ---
  const playDialogueAI = useCallback(async (material: ChoukaiMaterial) => {
    const cache = ttsCacheRef.current;

    stopFlagRef.current = false;
    setShowScript(true);
    setIsPlaying(true);
    setPlayedLines(0);

    for (let i = 0; i < material.dialogue.length; i++) {
      if (stopFlagRef.current) break;

      const key = `${material.id}-${i}`;
      const line = material.dialogue[i];
      const cleanText = cleanForSpeech(line.text);
      if (!cleanText) continue;

      setActiveSpeakingIdx(i);
      setActiveSpeakerId(line.speaker);
      setPlayedLines(i + 1);

      if (cache.has(key)) {
        await playAudioBlob(cache.get(key)!);
      } else {
        // Fall back to pause for non-generated lines
        await new Promise<void>(resolve => {
          const t = setTimeout(resolve, 1500 / playbackSpeed);
          playTimeoutRef.current.push(t);
        });
      }

      setActiveSpeakerId(null);

      // Natural pause between speakers
      if (i < material.dialogue.length - 1 && !stopFlagRef.current) {
        const nextSpeaker = material.dialogue[i + 1].speaker;
        const pauseDuration = nextSpeaker !== line.speaker ? 700 : 350;
        await new Promise<void>(resolve => {
          const t = setTimeout(resolve, pauseDuration / playbackSpeed);
          playTimeoutRef.current.push(t);
        });
      }
    }

    setIsPlaying(false);
    setActiveSpeakingIdx(null);
    setActiveSpeakerId(null);
    setPlayedLines(0);
  }, [playAudioBlob, playbackSpeed]);

  // --- Browser TTS dialog playback
  const playDialogueBrowser = useCallback(async (material: ChoukaiMaterial) => {
    if (typeof window === 'undefined' || !('speechSynthesis' in window)) return;

    stopFlagRef.current = false;
    window.speechSynthesis.cancel();
    setShowScript(true);
    setIsPlaying(true);
    setPlayedLines(0);
    startChromeResume();

    for (let i = 0; i < material.dialogue.length; i++) {
      if (stopFlagRef.current) break;

      const line = material.dialogue[i];
      const cleanText = cleanForSpeech(line.text);
      if (!cleanText) continue;

      setActiveSpeakingIdx(i);
      setActiveSpeakerId(line.speaker);
      setPlayedLines(i + 1);

      const params = getSpeakerVoiceParams(line.speaker, material, playbackSpeed);

      await new Promise<void>((resolve) => {
        // Do NOT call cancel() here — that was causing the choppy audio!
        const utterance = new SpeechSynthesisUtterance(cleanText);
        utterance.lang = 'ja-JP';
        utterance.rate = params.rate;
        utterance.pitch = params.pitch;
        utterance.volume = params.volume;
        if (params.voice) utterance.voice = params.voice;

        utterance.onend = () => {
          setActiveSpeakerId(null);
          resolve();
        };
        utterance.onerror = () => {
          setActiveSpeakerId(null);
          resolve();
        };

        if (stopFlagRef.current) {
          window.speechSynthesis.cancel();
          setActiveSpeakerId(null);
          resolve();
        } else {
          window.speechSynthesis.speak(utterance);
        }
      });

      // Natural pause between speakers (shorter for same speaker, longer for speaker change)
      if (i < material.dialogue.length - 1 && !stopFlagRef.current) {
        const nextSpeaker = material.dialogue[i + 1].speaker;
        const pauseDuration = nextSpeaker !== line.speaker ? 700 : 350;
        await new Promise<void>(resolve => {
          const t = setTimeout(resolve, pauseDuration / playbackSpeed);
          playTimeoutRef.current.push(t);
        });
      }
    }

    stopChromeResume();
    setIsPlaying(false);
    setActiveSpeakingIdx(null);
    setActiveSpeakerId(null);
    setPlayedLines(0);
  }, [playbackSpeed, getSpeakerVoiceParams, startChromeResume, stopChromeResume]);

  const playDialogue = useCallback(async () => {
    if (!currentMaterial) return;

    if (isPlaying) {
      // Stop all playback
      stopFlagRef.current = true;
      if (typeof window !== 'undefined' && 'speechSynthesis' in window) {
        window.speechSynthesis.cancel();
      }
      if (currentAudioRef.current) {
        currentAudioRef.current.pause();
        currentAudioRef.current.currentTime = 0;
        currentAudioRef.current = null;
      }
      playTimeoutRef.current.forEach(t => clearTimeout(t));
      playTimeoutRef.current = [];
      stopChromeResume();
      setIsPlaying(false);
      setActiveSpeakingIdx(null);
      setActiveSpeakerId(null);
      return;
    }

    // Choose playback mode
    if (audioMode === 'ai' && ttsReady) {
      playDialogueAI(currentMaterial);
    } else {
      playDialogueBrowser(currentMaterial);
    }
  }, [currentMaterial, isPlaying, audioMode, ttsReady, playDialogueAI, playDialogueBrowser, stopChromeResume]);

  // Play single line (for clicking on script)
  const playSingleLine = useCallback((text: string, speakerId: string, lineIdx?: number) => {
    if (!currentMaterial) return;

    // Check TTS cache first for AI mode
    if (audioMode === 'ai' && lineIdx !== undefined) {
      const key = `${currentMaterial.id}-${lineIdx}`;
      const cache = ttsCacheRef.current;
      if (cache.has(key)) {
        // Stop any current playback
        if (currentAudioRef.current) {
          currentAudioRef.current.pause();
          currentAudioRef.current = null;
        }
        if (typeof window !== 'undefined' && 'speechSynthesis' in window) {
          window.speechSynthesis.cancel();
        }
        const audio = new Audio(cache.get(key)!);
        audio.playbackRate = playbackSpeed;
        currentAudioRef.current = audio;
        setActiveSpeakingIdx(lineIdx);
        setActiveSpeakerId(speakerId);
        audio.addEventListener('ended', () => {
          if (currentAudioRef.current === audio) currentAudioRef.current = null;
          setActiveSpeakingIdx(null);
          setActiveSpeakerId(null);
        });
        audio.play().catch(() => {});
        return;
      }
    }

    // Fall back to Web Speech API
    if (typeof window === 'undefined' || !('speechSynthesis' in window)) return;

    if (currentAudioRef.current) {
      currentAudioRef.current.pause();
      currentAudioRef.current = null;
    }
    window.speechSynthesis.cancel();
    const cleanText = cleanForSpeech(text);
    if (!cleanText) return;

    const params = getSpeakerVoiceParams(speakerId, currentMaterial, playbackSpeed);

    const utterance = new SpeechSynthesisUtterance(cleanText);
    utterance.lang = 'ja-JP';
    utterance.rate = params.rate;
    utterance.pitch = params.pitch;
    utterance.volume = params.volume;
    if (params.voice) utterance.voice = params.voice;
    window.speechSynthesis.speak(utterance);
  }, [currentMaterial, playbackSpeed, audioMode, getSpeakerVoiceParams]);

  const goToMaterial = (idx: number) => {
    stopFlagRef.current = true;
    preGenAbortRef.current = true;
    if (typeof window !== 'undefined' && 'speechSynthesis' in window) {
      window.speechSynthesis.cancel();
    }
    if (currentAudioRef.current) {
      currentAudioRef.current.pause();
      currentAudioRef.current.currentTime = 0;
      currentAudioRef.current = null;
    }
    stopChromeResume();
    playTimeoutRef.current.forEach(t => clearTimeout(t));
    playTimeoutRef.current = [];
    setIsPlaying(false);
    setActiveSpeakingIdx(null);
    setActiveSpeakerId(null);
    setShowScript(false);
    setSelectedAnswer(null);
    setHasStartedQuiz(false);
    setCurrentIndex(idx);
    setCurrentMaterial(materials[idx]);
  };

  const nextMaterial = () => {
    stopFlagRef.current = true;
    preGenAbortRef.current = true;
    if (typeof window !== 'undefined' && 'speechSynthesis' in window) {
      window.speechSynthesis.cancel();
    }
    if (currentAudioRef.current) {
      currentAudioRef.current.pause();
      currentAudioRef.current.currentTime = 0;
      currentAudioRef.current = null;
    }
    stopChromeResume();
    playTimeoutRef.current.forEach(t => clearTimeout(t));
    playTimeoutRef.current = [];
    setIsPlaying(false);
    setActiveSpeakingIdx(null);
    setActiveSpeakerId(null);
    setShowScript(false);
    setSelectedAnswer(null);
    setHasStartedQuiz(false);

    if (activeTab === 'ai' && aiMaterial) {
      generateNewMaterial();
    } else {
      const nextIdx = (currentIndex + 1) % materials.length;
      setCurrentIndex(nextIdx);
      setCurrentMaterial(materials[nextIdx]);
    }
  };

  const handleAnswer = (answerIdx: number) => {
    if (selectedAnswer !== null || !currentMaterial) return;
    setSelectedAnswer(answerIdx);
    setHasStartedQuiz(true);
    setScore(prev => ({
      correct: prev.correct + (answerIdx === currentMaterial.quiz.answer ? 1 : 0),
      total: prev.total + 1,
    }));
  };

  const generateNewMaterial = async () => {
    setIsGenerating(true);
    try {
      const res = await fetch('/api/choukai/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'generate' }),
      });
      const data = await res.json();
      if (data.material) {
        setAiMaterial(data.material);
        setCurrentMaterial(data.material);
        setIsPlaying(false);
        setActiveSpeakingIdx(null);
        setActiveSpeakerId(null);
        setShowScript(false);
        setSelectedAnswer(null);
        setHasStartedQuiz(false);
      }
    } catch (error) {
      console.error('Generate error:', error);
    } finally {
      setIsGenerating(false);
    }
  };

  const displayMaterial = activeTab === 'ai' ? (aiMaterial || currentMaterial) : currentMaterial;

  // Pre-generate when material changes
  useEffect(() => {
    if (displayMaterial && audioMode === 'ai') {
      preGenerateDialogueAudio(displayMaterial);
    }
    return () => { preGenAbortRef.current = true; };
  }, [displayMaterial?.id, audioMode, preGenerateDialogueAudio]);

  const stopAndReset = () => {
    stopFlagRef.current = true;
    if (typeof window !== 'undefined' && 'speechSynthesis' in window) {
      window.speechSynthesis.cancel();
    }
    if (currentAudioRef.current) {
      currentAudioRef.current.pause();
      currentAudioRef.current.currentTime = 0;
      currentAudioRef.current = null;
    }
    stopChromeResume();
    playTimeoutRef.current.forEach(t => clearTimeout(t));
    playTimeoutRef.current = [];
    setIsPlaying(false);
    setActiveSpeakingIdx(null);
    setActiveSpeakerId(null);
  };

  // Check if we have distinct male/female voices
  const hasDistinctVoices = voicesReady && voicesRef.current.female && voicesRef.current.male
    && voicesRef.current.female.name !== voicesRef.current.male.name;

  return (
    <div className="flex flex-col h-full min-h-0">
      {/* Header */}
      <div className="shrink-0 space-y-3">
        <div className="flex items-center justify-between flex-wrap gap-3">
          <div className="space-y-1">
            <h2 className="text-2xl md:text-3xl font-black tracking-tight flex items-center gap-2">
              <Headphones className="text-teal-500" size={28} /> Choukai Lab
            </h2>
            <p className="text-sm text-muted-foreground">
              Latih pendengaran dengan dialog N5 — Dengarkan dan pahami percakapan
            </p>
          </div>

          <div className="flex items-center gap-2 flex-wrap">
            {/* Score */}
            <div className={cn(
              'flex items-center gap-1.5 px-3 py-1.5 rounded-xl border text-xs font-bold transition-colors',
              score.total > 0
                ? score.correct === score.total
                  ? 'bg-emerald-50 border-emerald-200 text-emerald-700'
                  : score.correct >= score.total * 0.7
                    ? 'bg-amber-50 border-amber-200 text-amber-700'
                    : 'bg-red-50 border-red-200 text-red-600'
                : 'border-border text-muted-foreground'
            )}>
              <CheckCircle2 size={14} />
              <span>{score.correct}/{score.total}</span>
              {score.total > 0 && (
                <span className="text-[10px] font-semibold opacity-70">
                  ({Math.round((score.correct / score.total) * 100)}%)
                </span>
              )}
            </div>

            {/* Audio Mode Toggle */}
            <div className="flex rounded-xl border bg-muted/50 p-1">
              <button
                onClick={() => { setAudioMode('ai'); }}
                className={cn(
                  'px-3 sm:px-4 py-2 rounded-lg text-xs font-bold transition-all flex items-center gap-1.5',
                  audioMode === 'ai'
                    ? 'bg-gradient-to-r from-teal-600 to-emerald-600 text-white shadow-sm'
                    : 'text-muted-foreground hover:text-foreground'
                )}
              >
                <Volume2 size={14} />
                <span className="hidden sm:inline">AI Audio</span>
                {audioMode === 'ai' && ttsReady && (
                  <CheckCircle2 size={12} className="text-green-300" />
                )}
              </button>
              <button
                onClick={() => { setAudioMode('browser'); }}
                className={cn(
                  'px-3 sm:px-4 py-2 rounded-lg text-xs font-bold transition-all flex items-center gap-1.5',
                  audioMode === 'browser'
                    ? 'bg-gradient-to-r from-teal-600 to-emerald-600 text-white shadow-sm'
                    : 'text-muted-foreground hover:text-foreground'
                )}
              >
                <Globe size={14} />
                <span className="hidden sm:inline">Browser</span>
              </button>
            </div>

            {/* Tab Toggle */}
            <div className="flex rounded-xl border bg-muted/50 p-1">
              <button
                onClick={() => { stopAndReset(); setActiveTab('library'); if (currentMaterial) setCurrentMaterial(materials[currentIndex]); }}
                className={cn(
                  'px-3 sm:px-4 py-2 rounded-lg text-xs font-bold transition-all flex items-center gap-1.5',
                  activeTab === 'library'
                    ? 'bg-teal-600 text-white shadow-sm'
                    : 'text-muted-foreground hover:text-foreground'
                )}
              >
                <BookOpen size={14} />
                <span className="hidden sm:inline">Materi</span>
              </button>
              <button
                onClick={() => { stopAndReset(); setActiveTab('ai'); if (aiMaterial) setCurrentMaterial(aiMaterial); }}
                className={cn(
                  'px-3 sm:px-4 py-2 rounded-lg text-xs font-bold transition-all flex items-center gap-1.5',
                  activeTab === 'ai'
                    ? 'bg-teal-600 text-white shadow-sm'
                    : 'text-muted-foreground hover:text-foreground'
                )}
              >
                <Sparkles size={14} />
                <span className="hidden sm:inline">AI</span>
              </button>
            </div>
          </div>
        </div>
      </div>

      <div className="flex-1 flex flex-col lg:flex-row gap-3 mt-3 min-h-0">
        {/* Material List (sidebar) */}
        <Card className="lg:w-72 shrink-0 p-3 border shadow-sm overflow-y-auto">
          <h3 className="text-xs font-bold uppercase tracking-widest text-muted-foreground mb-3 px-1">
            {activeTab === 'library' ? `Daftar Materi (${materials.length})` : 'AI Generated'}
          </h3>

          <div className="space-y-1.5">
            {activeTab === 'library' ? (
              materials.map((m, i) => (
                <button
                  key={m.id}
                  onClick={() => goToMaterial(i)}
                  className={cn(
                    'w-full text-left p-3 rounded-xl transition-all text-sm',
                    currentIndex === i && activeTab === 'library'
                      ? 'bg-teal-50 dark:bg-teal-950/30 border border-teal-200 shadow-sm'
                      : 'hover:bg-muted border border-transparent'
                  )}
                >
                  <div className="flex items-center gap-2.5">
                    <span className="text-xl">{m.emoji}</span>
                    <div className="min-w-0 flex-1">
                      <p className="font-bold text-xs truncate">{m.title}</p>
                      <div className="flex items-center gap-1.5 mt-0.5">
                        <p className="text-[10px] text-muted-foreground truncate">{m.topic}</p>
                        <Badge variant="outline" className="text-[9px] px-1.5 py-0 h-4 shrink-0">
                          {m.difficulty === 'easy' ? 'Mudah' : 'Menengah'}
                        </Badge>
                      </div>
                      {/* Speaker preview */}
                      <div className="flex items-center gap-1 mt-1">
                        {m.speakers.map(s => (
                          <span key={s.id} className={cn(
                            'text-[9px] px-1.5 py-0.5 rounded-full font-semibold',
                            s.colorClass === 'rose' ? 'bg-rose-100 text-rose-700' : 'bg-blue-100 text-blue-700'
                          )}>
                            {s.emoji} {s.nameRo}
                          </span>
                        ))}
                      </div>
                    </div>
                  </div>
                </button>
              ))
            ) : (
              <div className="space-y-3">
                <p className="text-xs text-muted-foreground px-1">
                  AI akan membuat materi listening baru berdasarkan topik acak N5.
                </p>
                <Button
                  onClick={generateNewMaterial}
                  disabled={isGenerating}
                  className="w-full rounded-xl gap-2"
                  variant="outline"
                >
                  {isGenerating ? (
                    <Loader2 size={14} className="animate-spin" />
                  ) : (
                    <Sparkles size={14} />
                  )}
                  {isGenerating ? 'Membuat...' : 'Generate Materi Baru'}
                </Button>

                {aiMaterial && (
                  <div className="p-3 rounded-xl bg-teal-50 dark:bg-teal-950/30 border border-teal-200 shadow-sm">
                    <div className="flex items-center gap-2 mb-1">
                      <span className="text-lg">{aiMaterial.emoji}</span>
                      <p className="font-bold text-xs text-teal-900">{aiMaterial.title}</p>
                    </div>
                    <p className="text-[10px] text-teal-700">{aiMaterial.topic}</p>
                  </div>
                )}
              </div>
            )}
          </div>

          {/* Tips */}
          <div className="mt-3 p-3 rounded-xl bg-amber-50 dark:bg-amber-950/20 border border-amber-100 dark:border-amber-900/50 text-xs text-amber-900 space-y-1.5">
            <p className="font-bold flex items-center gap-1"><Sparkles size={12} /> Tips Belajar</p>
            <ul className="space-y-0.5 text-amber-800 ml-4 list-disc">
              <li>Pertama dengarkan <strong>tanpa lihat naskah</strong></li>
              <li>Perhatikan siapa yang berbicara</li>
              <li>Gunakan speed slider untuk atur kecepatan</li>
              <li>Klik baris dialog untuk putar ulang</li>
            </ul>
          </div>
        </Card>

        {/* Main Content */}
        <Card className="flex-1 flex flex-col overflow-hidden border shadow-sm min-h-0">
          {!displayMaterial ? (
            <div className="flex-1 flex flex-col items-center justify-center py-16 text-center px-4">
              <div className="text-6xl mb-4 animate-bounce">🎧</div>
              <h3 className="text-lg font-bold text-muted-foreground mb-2">Pilih Materi</h3>
              <p className="text-sm text-muted-foreground">
                {activeTab === 'ai'
                  ? 'Klik "Generate Materi Baru" untuk membuat materi listening dengan AI'
                  : 'Pilih salah satu materi dari daftar di sebelah kiri'}
              </p>
            </div>
          ) : (
            <div className="flex-1 overflow-y-auto">
              {/* Material Header & Characters */}
              <div className="p-4 md:p-5 border-b bg-gradient-to-br from-teal-50 via-white to-purple-50/30 dark:from-teal-950/20 dark:via-card dark:to-purple-950/10">
                <div className="flex items-start gap-4">
                  <div className="text-4xl md:text-5xl p-3 bg-white dark:bg-card rounded-2xl border shadow-sm shrink-0">
                    {displayMaterial.emoji}
                  </div>
                  <div className="min-w-0 flex-1">
                    <h3 className="text-lg font-bold text-foreground">{displayMaterial.title}</h3>
                    <p className="text-sm text-muted-foreground mt-1 leading-relaxed">{displayMaterial.scenario}</p>
                    <div className="flex gap-2 mt-2 flex-wrap">
                      <Badge variant="secondary" className="text-[10px]">{displayMaterial.topic}</Badge>
                      <Badge variant="outline" className="text-[10px]">
                        {displayMaterial.difficulty === 'easy' ? '🟢 Mudah' : '🟡 Menengah'}
                      </Badge>
                      <Badge variant="outline" className="text-[10px]">
                        💬 {displayMaterial.dialogue.length} baris
                      </Badge>
                    </div>
                  </div>
                </div>

                {/* Characters Section */}
                {displayMaterial.speakers && displayMaterial.speakers.length >= 2 && (
                  <div className="mt-4">
                    <div className="flex items-center gap-2 mb-2.5">
                      <Users size={14} className="text-muted-foreground" />
                      <span className="text-xs font-bold uppercase tracking-widest text-muted-foreground">
                        Tokoh dalam Dialog
                      </span>
                    </div>
                    <div className="grid grid-cols-2 gap-2.5">
                      {displayMaterial.speakers.map(speaker => {
                        const colors = getSpeakerColors(speaker.id, displayMaterial);
                        return (
                          <div
                            key={speaker.id}
                            className={cn(
                              'flex items-center gap-3 p-3 rounded-xl border-2 transition-all duration-500',
                              activeSpeakerId === speaker.id
                                ? `${colors.activeBg} ${colors.border} ${colors.ring} ring-2 shadow-md scale-[1.02]`
                                : `${colors.bg} border-transparent`
                            )}
                          >
                            <div className={cn(
                              'text-2xl w-10 h-10 rounded-full flex items-center justify-center shrink-0 transition-all',
                              activeSpeakerId === speaker.id
                                ? `${colors.badge} text-white shadow-lg scale-110`
                                : `${colors.bg} ${colors.border} border`
                            )}>
                              {activeSpeakerId === speaker.id ? (
                                <Volume2 size={18} className="animate-pulse" />
                              ) : (
                                speaker.emoji
                              )}
                            </div>
                            <div className="min-w-0">
                              <p className="font-black text-sm font-jp">
                                {speaker.name}
                              </p>
                              <p className="text-[10px] text-muted-foreground font-mono">{speaker.nameRo}</p>
                              <p className={cn('text-[10px] font-bold mt-0.5', colors.text)}>
                                {speaker.role}
                              </p>
                            </div>
                          </div>
                        );
                      })}
                    </div>
                  </div>
                )}

                {/* Play Controls */}
                <div className="mt-4 flex flex-col sm:flex-row items-start sm:items-center gap-3">
                  <Button
                    onClick={playDialogue}
                    className={cn(
                      'rounded-xl gap-2 shadow-md min-w-[170px] font-bold animate-gradient-bg bg-[length:200%_200%]',
                      isPlaying
                        ? 'bg-red-500 hover:bg-red-600 shadow-red-200'
                        : 'bg-gradient-to-r from-teal-600 via-emerald-500 to-teal-600 hover:from-teal-700 hover:via-emerald-600 hover:to-teal-700 shadow-teal-200'
                    )}
                  >
                    {isPlaying ? (
                      <><Pause size={18} /> Berhenti</>
                    ) : (
                      <><Play size={18} /> {audioMode === 'ai' && ttsReady ? 'Putar Dialog (AI)' : 'Putar Dialog'}</>
                    )}
                  </Button>

                  {/* Speed Control */}
                  <div className="flex items-center gap-3 px-4 py-2 rounded-xl border bg-white/80 dark:bg-card/80">
                    <Gauge size={14} className="text-muted-foreground shrink-0" />
                    <span className="text-xs text-muted-foreground font-bold shrink-0">Speed</span>
                    <Slider
                      value={[playbackSpeed]}
                      onValueChange={([v]) => setPlaybackSpeed(v)}
                      min={0.4}
                      max={1.2}
                      step={0.05}
                      className="w-24 h-4"
                      disabled={isPlaying}
                    />
                    <span className="text-xs font-mono text-muted-foreground font-bold min-w-[36px] text-right">
                      {playbackSpeed.toFixed(2)}x
                    </span>
                  </div>

                  {isPlaying && activeSpeakerId && displayMaterial.speakers && (
                    <div className="flex items-center gap-2 flex-wrap">
                      {/* Audio wave bars */}
                      <div className="flex items-end gap-[3px] h-4">
                        <span className="w-[3px] rounded-full bg-teal-500 audio-bar-1" />
                        <span className="w-[3px] rounded-full bg-emerald-500 audio-bar-2" />
                        <span className="w-[3px] rounded-full bg-teal-400 audio-bar-3" />
                      </div>
                      <div className="flex items-center gap-2 text-orange-500 text-xs font-semibold">
                        Memutar...
                      </div>
                      {(() => {
                        const speaker = getSpeakerInfo(displayMaterial, activeSpeakerId);
                        if (!speaker) return null;
                        const colors = getSpeakerColors(activeSpeakerId, displayMaterial);
                        return (
                          <div className={cn(
                            'flex items-center gap-1.5 px-3 py-1.5 rounded-full text-white text-xs font-black animate-pulse shadow-md',
                            `bg-gradient-to-r ${colors.gradient} ${colors.shadow}`
                          )}>
                            {speaker.emoji} {speaker.nameRo} ({speaker.gender === 'wanita' ? 'Wanita' : 'Pria'})
                          </div>
                        );
                      })()}
                    </div>
                  )}

                  {/* Dialogue Progress Bar */}
                  {isPlaying && displayMaterial && (
                    <div className="w-full mt-1">
                      <div className="flex items-center justify-between mb-1">
                        <span className="text-[10px] font-bold text-muted-foreground">
                          {playedLines}/{displayMaterial.dialogue.length} baris diputar
                        </span>
                      </div>
                      <div className="w-full h-1.5 bg-muted rounded-full overflow-hidden">
                        <div
                          className="h-full bg-gradient-to-r from-teal-500 to-emerald-500 rounded-full transition-all duration-500 ease-out"
                          style={{ width: `${displayMaterial.dialogue.length > 0 ? (playedLines / displayMaterial.dialogue.length) * 100 : 0}%` }}
                        />
                      </div>
                    </div>
                  )}
                </div>

                {/* Pre-generation progress bar */}
                {audioMode === 'ai' && isPreGenerating && displayMaterial && (
                  <div className="mt-3">
                    <div className="flex items-center gap-2 mb-1">
                      <Loader2 size={12} className="animate-spin text-teal-500" />
                      <span className="text-[10px] font-bold text-teal-600">
                        Membuat audio AI... {preGenProgress.current}/{preGenProgress.total}
                      </span>
                    </div>
                    <div className="w-full h-1.5 bg-muted rounded-full overflow-hidden">
                      <div
                        className="h-full bg-gradient-to-r from-teal-500 to-emerald-500 rounded-full transition-all duration-300"
                        style={{ width: `${preGenProgress.total > 0 ? (preGenProgress.current / preGenProgress.total) * 100 : 0}%` }}
                      />
                    </div>
                  </div>
                )}

                {/* AI Audio Ready indicator */}
                {audioMode === 'ai' && ttsReady && !isPreGenerating && (
                  <div className="mt-3 flex items-center gap-2 px-3 py-1.5 rounded-lg bg-green-50 dark:bg-green-950/20 border border-green-200 dark:border-green-900/50">
                    <CheckCircle2 size={14} className="text-green-500" />
                    <span className="text-[10px] font-bold text-green-700">AI Audio Siap — Suara berbeda untuk setiap pembicara</span>
                  </div>
                )}

                {/* AI Audio voice info */}
                {audioMode === 'ai' && displayMaterial?.speakers && (
                  <div className="mt-2 flex items-center gap-3 flex-wrap">
                    {displayMaterial.speakers.map(s => (
                      <span key={s.id} className={cn(
                        'text-[9px] px-2 py-0.5 rounded-full font-semibold',
                        s.gender === 'wanita'
                          ? 'bg-rose-100 text-rose-600'
                          : 'bg-blue-100 text-blue-600'
                      )}>
                        {s.gender === 'wanita' ? 'A: xiaochen (jelas)' : 'B: kazi (jelas)'}
                      </span>
                    ))}
                  </div>
                )}
              </div>

              {/* Context / Situation Card */}
              {displayMaterial.context && (
                <div className="mx-4 md:mx-5 mt-4 p-3.5 rounded-xl bg-sky-50 dark:bg-sky-950/20 border border-sky-100 dark:border-sky-900/50">
                  <div className="flex items-start gap-2.5">
                    <MessageCircle size={16} className="text-sky-500 shrink-0 mt-0.5" />
                    <div>
                      <p className="text-xs font-bold text-sky-800 dark:text-sky-300 mb-1">Situasi:</p>
                      <p className="text-sm text-sky-700 dark:text-sky-400 leading-relaxed">
                        {displayMaterial.context}
                      </p>
                    </div>
                  </div>
                </div>
              )}

              {/* Quiz Section */}
              <div className="p-4 md:p-5">
                <h4 className="text-sm font-bold uppercase tracking-widest text-muted-foreground mb-4 flex items-center gap-2">
                  <Headphones size={14} /> Soal Pemahaman
                </h4>

                <p className="font-medium text-foreground text-base mb-4">
                  {displayMaterial.quiz.question}
                </p>

                <div className="grid grid-cols-1 sm:grid-cols-2 gap-2.5">
                  {displayMaterial.quiz.options.map((opt, i) => (
                    <button
                      key={i}
                      onClick={() => handleAnswer(i)}
                      disabled={selectedAnswer !== null}
                      className={cn(
                        'p-3.5 rounded-xl text-left border-2 transition-all font-medium text-sm',
                        selectedAnswer === null
                          ? 'border-border hover:border-teal-300 hover:bg-teal-50/50 cursor-pointer hover:shadow-sm'
                          : selectedAnswer === i
                            ? i === displayMaterial.quiz.answer
                              ? 'bg-emerald-50 border-emerald-400 text-emerald-800 shadow-sm'
                              : 'bg-red-50 border-red-400 text-red-800 shadow-sm'
                            : i === displayMaterial.quiz.answer
                              ? 'bg-emerald-50 border-emerald-300 text-emerald-700'
                              : 'opacity-50 cursor-not-allowed'
                      )}
                    >
                      <div className="flex items-center gap-2.5">
                        <span className={cn(
                          'w-7 h-7 rounded-full border-2 flex items-center justify-center text-xs font-bold shrink-0 transition-colors',
                          selectedAnswer === null && 'border-border',
                          selectedAnswer === i && i !== displayMaterial.quiz.answer && 'border-red-300 bg-red-500 text-white',
                          selectedAnswer === null && i === displayMaterial.quiz.answer && 'border-emerald-300',
                          selectedAnswer !== null && i === displayMaterial.quiz.answer && 'border-emerald-400 bg-emerald-500 text-white',
                          selectedAnswer !== null && i !== displayMaterial.quiz.answer && selectedAnswer !== i && 'border-border bg-muted',
                        )}>
                          {selectedAnswer !== null && i === displayMaterial.quiz.answer ? (
                            <CheckCircle2 size={14} />
                          ) : selectedAnswer === i && i !== displayMaterial.quiz.answer ? (
                            <XCircle size={14} />
                          ) : (
                            String.fromCharCode(65 + i)
                          )}
                        </span>
                        <span>{opt}</span>
                      </div>
                    </button>
                  ))}
                </div>

                {/* Explanation */}
                {selectedAnswer !== null && (
                  <div className={cn(
                    'mt-4 p-4 rounded-xl border shadow-sm',
                    selectedAnswer === displayMaterial.quiz.answer
                      ? 'bg-emerald-50 border-emerald-100'
                      : 'bg-red-50 border-red-100'
                  )}>
                    <div className="flex items-center gap-2 mb-2">
                      <div className={cn(
                        'w-8 h-8 rounded-full flex items-center justify-center text-white font-bold text-sm shadow-sm',
                        selectedAnswer === displayMaterial.quiz.answer ? 'bg-emerald-500' : 'bg-red-500'
                      )}>
                        {selectedAnswer === displayMaterial.quiz.answer ? '✓' : '×'}
                      </div>
                      <span className={cn(
                        'font-bold',
                        selectedAnswer === displayMaterial.quiz.answer ? 'text-emerald-800' : 'text-red-800'
                      )}>
                        {selectedAnswer === displayMaterial.quiz.answer ? 'Benar Sekali!' : 'Kurang Tepat'}
                      </span>
                    </div>
                    <p className="text-sm text-muted-foreground leading-relaxed">
                      {displayMaterial.quiz.explanation}
                    </p>
                    <div className="mt-4 flex items-center justify-between">
                      <p className="text-xs text-muted-foreground">
                        Skor: <span className="font-bold text-foreground">{score.correct}</span> dari{' '}
                        <span className="font-bold text-foreground">{score.total}</span>
                      </p>
                      <Button
                        onClick={nextMaterial}
                        className="rounded-xl gap-2 bg-teal-600 hover:bg-teal-700 text-white shadow-sm"
                      >
                        Selanjutnya <ChevronRight size={16} />
                      </Button>
                    </div>
                  </div>
                )}
              </div>

              {/* Script Toggle */}
              <div className="px-4 md:px-6 pb-2">
                <button
                  onClick={() => setShowScript(!showScript)}
                  className="flex items-center gap-2 text-xs text-muted-foreground hover:text-teal-600 font-semibold transition-colors"
                >
                  {showScript ? <EyeOff size={14} /> : <Eye size={14} />}
                  {showScript ? 'Sembunyikan Naskah' : 'Lihat Naskah Dialog'}
                </button>
              </div>

              {/* Script */}
              {showScript && (
                <div className="px-4 md:px-6 pb-6">
                  <div ref={scrollRef} className="border rounded-xl p-4 bg-gradient-to-b from-muted/30 to-background space-y-3 max-h-[400px] overflow-y-auto">
                    <h4 className="text-xs font-bold uppercase tracking-widest text-muted-foreground mb-3 flex items-center gap-2">
                      <BookOpen size={14} /> Naskah Dialog
                      <Badge variant="outline" className="text-[9px] ml-auto">
                        {displayMaterial.dialogue.length} baris
                      </Badge>
                    </h4>
                    {displayMaterial.dialogue.map((line, i) => {
                      const speaker = getSpeakerInfo(displayMaterial, line.speaker);
                      const colors = getSpeakerColors(line.speaker, displayMaterial);
                      const isActive = activeSpeakingIdx === i;

                      return (
                        <div
                          key={i}
                          data-line={i}
                          className={cn(
                            'flex gap-3 p-3 rounded-xl transition-all cursor-pointer',
                            isActive
                              ? `${colors.activeBg} ring-2 ${colors.ring} shadow-md scale-[1.01]`
                              : 'hover:bg-muted/50'
                          )}
                          onClick={() => playSingleLine(line.text, line.speaker, i)}
                        >
                          {/* Speaker avatar */}
                          <div className={cn(
                            'w-10 h-10 rounded-full font-bold flex items-center justify-center shrink-0 text-sm shadow-sm transition-all',
                            isActive
                              ? `${colors.badge} text-white scale-110`
                              : `${colors.bg} ${colors.border} border`
                          )}>
                            {isActive ? (
                              <Volume2 size={16} className="animate-pulse" />
                            ) : (
                              <span className="text-lg">{speaker?.emoji || line.speaker}</span>
                            )}
                          </div>

                          {/* Content */}
                          <div className="min-w-0 space-y-1.5 flex-1">
                            {/* Speaker name */}
                            <div className="flex items-center gap-2">
                              <p className={cn('text-xs font-black', colors.text)}>
                                {speaker ? `${speaker.name} (${speaker.nameRo})` : line.speaker}
                              </p>
                              <span className={cn(
                                'text-[9px] px-1.5 py-0.5 rounded-full font-semibold',
                                speaker?.gender === 'wanita'
                                  ? 'bg-rose-100 text-rose-600'
                                  : 'bg-blue-100 text-blue-600'
                              )}>
                                {speaker?.gender === 'wanita' ? 'Wanita' : 'Pria'}
                              </span>
                              {isActive && (
                                <span className="text-[9px] px-1.5 py-0.5 rounded-full bg-orange-100 text-orange-600 font-bold animate-pulse">
                                  Sekarang berbicara
                                </span>
                              )}
                            </div>

                            {/* Japanese text */}
                            <p
                              className="text-base font-bold leading-relaxed font-jp"
                            >
                              {parseFurigana(line.text)}
                            </p>

                            {/* Romaji */}
                            <p className="text-xs text-muted-foreground font-mono">{line.ro}</p>

                            {/* Indonesian translation */}
                            <p className="text-xs text-muted-foreground/80 italic">{line.id}</p>
                          </div>

                          {/* Play button */}
                          <button
                            onClick={(e) => { e.stopPropagation(); playSingleLine(line.text, line.speaker, i); }}
                            className="shrink-0 p-2 rounded-lg hover:bg-teal-100 text-muted-foreground hover:text-teal-600 transition-colors self-center"
                            title="Putar baris ini"
                          >
                            <Play size={14} />
                          </button>
                        </div>
                      );
                    })}
                  </div>

                  {/* Voice Legend */}
                  {displayMaterial.speakers && (
                    <div className={cn(
                      'mt-3 p-3 rounded-xl border text-xs',
                      audioMode === 'ai'
                        ? 'bg-teal-50 dark:bg-teal-950/20 border-teal-100 dark:border-teal-900/50 text-teal-900'
                        : 'bg-emerald-50 dark:bg-emerald-950/20 border-emerald-100 dark:border-emerald-900/50 text-emerald-900'
                    )}>
                      <p className="font-bold flex items-center gap-1 mb-2">
                        <Volume2 size={12} />
                        {audioMode === 'ai' ? 'Suara AI TTS' : 'Perbedaan Suara Browser'}
                      </p>
                      <div className="space-y-1.5">
                        {displayMaterial.speakers.map(speaker => (
                          <div key={speaker.id} className="flex items-center gap-2">
                            <span className={cn(
                              'w-6 h-6 rounded-full flex items-center justify-center text-xs',
                              speaker.colorClass === 'rose'
                                ? 'bg-rose-100 text-rose-700'
                                : 'bg-blue-100 text-blue-700'
                            )}>
                              {speaker.emoji}
                            </span>
                            <span className="font-semibold">{speaker.nameRo} ({speaker.gender === 'wanita' ? 'Wanita' : 'Pria'})</span>
                            {audioMode === 'ai' ? (
                              <span className="ml-auto">
                                {speaker.gender === 'wanita' ? '🗣️ xiaochen (jelas)' : '🗣️ kazi (jelas)'}
                              </span>
                            ) : (
                              <span className="ml-auto">
                                {speaker.gender === 'wanita' ? '🎵 Nada tinggi + cepat' : '🎵 Nada rendah + lambat'}
                              </span>
                            )}
                          </div>
                        ))}
                      </div>
                      {audioMode === 'ai' ? (
                        ttsReady
                          ? <p className="mt-2 text-[10px] text-teal-600 italic">✅ Semua baris dialog sudah di-generate dengan suara AI berbeda.</p>
                          : <p className="mt-2 text-[10px] text-amber-600 italic">⏳ Audio sedang di-generate... Gunakan mode Browser sementara.</p>
                      ) : (
                        hasDistinctVoices
                          ? <p className="mt-2 text-[10px] text-emerald-600 italic">✅ Browser memiliki suara berbeda untuk pria dan wanita — perbedaan akan lebih jelas!</p>
                          : <p className="mt-2 text-[10px] text-amber-600 italic">⚠️ Browser hanya memiliki satu suara Jepang. Perbedaan dibuat melalui pitch (nada) yang berbeda jauh.</p>
                      )}
                    </div>
                  )}
                </div>
              )}
            </div>
          )}
        </Card>
      </div>
    </div>
  );
}
